{
  "workspace": ".picobot/workspace",
  "default_kb_name": "default",
  "default_language": "it",
  "ollama": {
    "base_url": "http://localhost:11434",
    "model": "qwen2.5:3b-instruct-q4_0",
    "timeout_s": 600
  },
  "use_embeddings": false,
  "embedding_model": "nomic-embed-text:latest",
  "summarizer_model": "qwen2.5:3b-instruct-q4_0",
  "memory_limits": {
    "max_history_lines": 300,
    "tail_lines": 900
  },
  "retrieval": {
    "enabled": true,
    "bm25_candidates": 9,
    "top_k": 3,
    "max_embed_chars": 4000,
    "max_context_chars": 5000,
    "bm25_k1": 1.2,
    "bm25_b": 0.75
  },
  "tools": {
    "base_dir": ".picobot/tools",
    "whisper_cpp_dir": ".picobot/tools/whisper.cpp",
    "whisper_model": ".picobot/tools/whisper.cpp/models/ggml-small.bin",
    "whisper_cpp_main_path": ".picobot/tools/whisper.cpp/build/bin/whisper-cli",
    "ytdlp_bin": ".picobot/tools/yt-dlp/bin/yt-dlp",
    "ffmpeg_bin": ".picobot/tools/ffmpeg/bin/ffmpeg",
    "arecord_bin": ".picobot/tools/arecord/bin/arecord",
    "aplay_bin": ".picobot/tools/aplay/bin/aplay",
    "piper_bin": ".picobot/tools/piper/bin/piper",
    "piper_model_it": ".picobot/tools/piper/models/it_IT-paola-medium.onnx",
    "piper_model_en": ".picobot/tools/piper/models/en_US-lessac-medium.onnx",
    "ytdlp_args": [
      "--js-runtimes",
      "node:/usr/bin/node"
    ]
  },
  "ui": {
    "use_emojis": true,
    "use_prompt_toolkit": true,
    "vi_mode": false
  },
  "telegram": {
    "enabled": true,
    "bot_token": "YOUR_BOT_TOKEN",
    "kb_per_chat": true,
    "pdf_auto_ingest": true,
    "stt_auto": true,
    "max_voice_seconds": 240,
    "send_transcript_flag": false,
    "debug_terminal": true
  },
  "podcast": {
    "enabled": true,
    "tts_backend": "piper",
    "audio_format": "mp3",
    "send_script_text": false,
    "send_transcript_flag": false,
    "max_minutes": 8,
    "target_words_per_minute": 150,
  
    "triggers": {
      "it": ["voglio un podcast su", "fammi un podcast su"],
      "en": ["i want a podcast about", "make a podcast about"]
    },
  
    "voices": {
      "it": {
        "narrator": { "voice_id": "it_IT-paola-medium" },
        "expert":   { "voice_id": "it_IT-aurora-medium" }
      },
      "en": {
        "narrator": { "voice_id": "en_US-amy-medium" },
        "expert":   { "voice_id": "en_US-ryan-high" }
      }
    }
  },
  "debug": {
    "enabled": true
  },
  "web": {
    "enabled": false
  }
}
