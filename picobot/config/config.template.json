{
  "workspace": ".picobot/workspace",

  "language": {
    "default": "it"
  },

  "kb": {
    "default_name": "default",
    "auto_route_questions": false
  },

  "ollama": {
    "base_url": "http://localhost:11434",
    "model": "qwen2.5:3b-instruct-q4_0",
    "timeout_s": 600
  },

  "memory_limits": {
    "max_history_lines": 300,
    "tail_lines": 900
  },

  "summary": {
    "mode": "single",
    "max_chars": 24000,
    "chunk_chars": 7000,
    "max_chunks": 6,
    "timeout_s": 600,
    "output_language": "auto"
  },

  "retrieval": {
    "enabled": true,
    "provider": "qdrant",
    "bm25_candidates": 9,
    "top_k": 3,
    "vector_top_k": 8,
    "final_top_k": 4,
    "max_context_chars": 5000,
    "max_embed_chars": 4000,
    "chunk_chars": 900,
    "chunk_overlap": 120,
    "bm25_k1": 1.2,
    "bm25_b": 0.75,
    "exact_match_boost": 0.03,
    "special_token_boosts": {
      "--trace": 0.2,
      "trace-fst": 0.2
    }
  },

  "tools": {
    "base_dir": ".picobot/tools",
    "bins": {
      "ytdlp": ".picobot/tools/yt-dlp/bin/yt-dlp",
      "ffmpeg": ".picobot/tools/ffmpeg/bin/ffmpeg",
      "whisper_cpp_cli": ".picobot/tools/whisper.cpp/build/bin/whisper-cli",
      "piper": ".picobot/tools/piper/bin/piper",
      "arecord": ".picobot/tools/arecord/bin/arecord",
      "aplay": ".picobot/tools/aplay/bin/aplay"
    },
    "models": {
      "whisper_cpp": ".picobot/tools/whisper.cpp/models/ggml-small.bin",
      "piper_it": ".picobot/tools/piper/models/it_IT-paola-medium.onnx",
      "piper_en": ".picobot/tools/piper/models/en_US-lessac-medium.onnx"
    },
    "youtube": {
      "enabled": true,
      "timeout_s": 180,
      "ytdlp_args": [
        "--js-runtimes",
        "node:/usr/bin/node"
      ],
      "prefer_sub_langs": [
        "it",
        "en"
      ]
    }
  },

  "sandbox": {
    "runtime": {
      "backend": "docker",
      "workspace_root": ".picobot/workspace",
      "runs_dir": ".picobot/workspace/sandbox_runs",
      "docker": {
        "enabled": true,
        "image": "picobot-sandbox:latest",
        "container_name": "picobot-sandbox",
        "docker_bin": "docker",
        "container_workspace_root": "/workspace",
        "auto_create": true,
        "extra_run_args": []
      }
    },
    "exec": {
      "enabled": true,
      "timeout_s": 180,
      "max_output_bytes": 200000,
      "allowed_bins": [
        "yt-dlp",
        "ffmpeg",
        "piper",
        "whisper-cli",
        "python",
        "bash"
      ]
    },
    "python": {
      "enabled": true,
      "timeout_s": 5,
      "cwd": ".picobot/workspace",
      "no_network": true
    },
    "file": {
      "enabled": true,
      "root": ".picobot/workspace",
      "max_bytes": 200000
    },
    "web": {
      "enabled": true,
      "timeout_s": 10,
      "max_bytes": 200000,
      "whitelist_domains": [
        "reuters.com",
        "apnews.com",
        "bbc.co.uk",
        "bbc.com",
        "theguardian.com",
        "ansa.it",
        "ilpost.it",
        "wired.com",
        "arstechnica.com"
      ]
    }
  },

  "web_search": {
    "enabled": true,
    "backend": "searxng",
    "searxng_url": "http://localhost:8080",
    "timeout_s": 10.0,
    "max_results": 5,
    "managed_backend": true,
    "health_timeout_s": 2.5,
    "startup_timeout_s": 45,
    "docker_compose_dir": "searxng",
    "docker_service_name": "searxng",
    "auto_restart_on_failure": true
  },

  "ui": {
    "use_emojis": true,
    "use_prompt_toolkit": true,
    "vi_mode": false
  },

  "telegram": {
    "enabled": false,
    "bot_token": "YOUR_BOT_TOKEN",
    "kb_per_chat": true,
    "pdf_auto_ingest": true,
    "stt_auto": true,
    "voice_stt_enabled": false,
    "send_transcript_flag": false,
    "echo_transcript": false,
    "max_voice_seconds": 240,
    "debug_terminal": true
  },

  "podcast": {
    "enabled": true,
    "tts_backend": "piper",
    "audio_format": "mp3",
    "default_minutes": 1,
    "max_minutes": 2,
    "target_words_per_minute": 150,
    "send_script_text": false,
    "output_dir": "outputs/podcasts",
    "triggers": {
      "it": [
        "voglio un podcast su",
        "fammi un podcast su"
      ],
      "en": [
        "i want a podcast about",
        "make a podcast about"
      ]
    },
    "voices": {
      "it": {
        "narrator": {
          "voice_id": "it_IT-paola-medium"
        },
        "expert": {
          "voice_id": "it_IT-aurora-medium"
        }
      },
      "en": {
        "narrator": {
          "voice_id": "en_US-amy-medium"
        },
        "expert": {
          "voice_id": "en_US-ryan-high"
        }
      }
    }
  },

  "debug": {
    "enabled": true
  },

  "qdrant": {
    "path": ".picobot/qdrant",
    "router_collection": "router_index",
    "docs_collection": "docs_index"
  },

  "vector": {
    "provider": "ollama",
    "base_url": "http://localhost:11434",
    "embed_model": "nomic-embed-text",
    "timeout_s": 60
  },

  "embeddings": {
    "provider": "ollama",
    "model": "nomic-embed-text",
    "batch_size": 16,
    "enabled": true
  },

  "router": {
    "enabled": true,
    "top_k": 5,
    "accept_threshold": 0.72,
    "margin": 0.05,
    "kb_probe_top_k": 2,
    "kb_probe_threshold": 0.55,
    "score_weights": {
      "vector": 0.45,
      "bm25": 0.25,
      "rerank": 0.25,
      "priority": 0.05
    },
    "reranker": {
      "enabled": false,
      "provider": "none",
      "model": ""
    }
  }
}
